ilderPageId\n          ? { ...page, backgroundConfig: newConfig }\n          : page\n      )\n    );\n  };\n\n  const handleAddTemplate = (type: 'javascript' | 'html', template: any) => {\n    const newWindow: WindowPanel = {\n      id: `window-${Date.now()}`,\n      title: template.name,\n      type,\n      content: type === 'html' ? template.code : '',\n      position: { \n        x: Math.random() * 300 + 50, \n        y: Math.random() * 200 + 50 \n      },\n      size: { width: 400, height: 300 },\n      jsCode: type === 'javascript' ? template.code : undefined\n    };\n\n    setWindows(prev => [...prev, newWindow]);\n  };\n\n  const handleWindowsChange = (newWindows: WindowPanel[]) => {\n    setWindows(newWindows);\n  };\n\n  return (\n    <div style={{\n      height: '100vh',\n      display: 'flex',\n      flexDirection: 'column',\n      fontFamily: '\"Segoe UI\", \"Arial\", sans-serif',\n      backgroundColor: '#f7f8fa',\n      color: '#2c3e50'\n    }}>\n      {/* Header */}\n      <header style={{\n        padding: '15px 20px',\n        backgroundColor: '#1a1a1a',\n        color: 'white',\n        borderBottom: '3px solid #0066cc',\n        boxShadow: '0 2px 8px rgba(0,0,0,0.15)'\n      }}>\n        <div style={{ display: 'flex', alignItems: 'center', gap: '15px' }}>\n          <img \n            src=\"/evs-logo.png\" \n            alt=\"EVS Automation\" \n            style={{ \n              height: '65px', \n              width: 'auto'\n            }} \n          />\n          <div>\n            <h1 style={{ \n              margin: 0, \n              fontSize: '28px',\n              fontWeight: '700',\n              letterSpacing: '0.5px',\n              fontFamily: '\"Segoe UI\", \"Arial Black\", sans-serif'\n            }}>\n              Web App & HMI Builder\n            </h1>\n            <p style={{ \n              margin: '2px 0 0 0', \n              fontSize: '13px', \n              opacity: 0.85,\n              fontWeight: '500',\n              let