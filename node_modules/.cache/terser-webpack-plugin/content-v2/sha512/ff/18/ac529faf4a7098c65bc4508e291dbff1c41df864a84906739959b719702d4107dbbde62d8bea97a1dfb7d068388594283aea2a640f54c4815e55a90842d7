         e.currentTarget.style.boxShadow = 'inset 1px 0 0 rgba(0,102,204,0.1)';\n                }}\n              >\n                {/* Clickable Tab Header */}\n                <div \n                  onClick={() => setRightPanelVisible(false)}\n                  style={{\n                    padding: '12px 16px',\n                    backgroundColor: '#0066cc',\n                    color: 'white',\n                    fontSize: '14px',\n                    fontWeight: '600',\n                    cursor: 'pointer',\n                    display: 'flex',\n                    alignItems: 'center',\n                    justifyContent: 'space-between',\n                    borderBottom: '1px solid #d6dbdf',\n                    fontFamily: '\"Segoe UI\", \"Arial\", sans-serif',\n                    userSelect: 'none'\n                  }}\n                >\n                  <span>EXPORT</span>\n                  <span style={{ fontSize: '12px' }}>▶</span>\n                </div>\n                <ExportManager \n                  builderPages={builderPages}\n                  onBuilderPagesChange={setBuilderPages}\n                  windows={windows} \n                  backgroundConfig={backgroundConfig}\n                  onBackgroundConfigChange={setBackgroundConfig}\n                  dataConnections={dataConnections}\n                  onWindowsChange={setWindows}\n                  onDataConnectionsChange={setDataConnections}\n                  codeEditorConfigs={codeEditorConfigs}\n                  onCodeEditorConfigsChange={setCodeEditorConfigs}\n                />\n              </div>\n            )}\n\n            {/* Right Panel Collapsed Tab */}\n            {!rightPanelVisible && (\n              <div \n                onClick={() => setRightPanelVisible(true)}\n                style={{\n                  width: '32px',\n                  backgroundColor: '#0066cc',\n                  borderLeft: '2px solid #d6dbdf',\n                  cursor: 'point