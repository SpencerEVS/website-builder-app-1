N.stringify(builderPages));\n    \n    // Also expose to window for compatibility\n    try {\n      Object.assign(window, { builderPages });\n    } catch (e) {\n      console.log('Could not set window.builderPages');\n    }\n  }, [builderPages]);\n\n  // Add event listener for navigation template\n  useEffect(() => {\n    const handleNavigationEvent = (event: any) => {\n      if (event.detail && event.detail.pageId) {\n        const { pageId } = event.detail;\n        console.log(`🎯 Received navigation event for page: ${pageId}`);\n        \n        // Check if the page exists and switch to it\n        const targetPage = builderPages.find(p => p.id === pageId);\n        if (targetPage && activeBuilderPageId !== pageId) {\n          console.log(`🔄 Switching to page: ${targetPage.name}`);\n          setActiveBuilderPageId(pageId);\n        } else if (!targetPage) {\n          console.log(`❌ Page ${pageId} not found in builder pages`);\n        } else {\n          console.log(`ℹ️ Already on page: ${pageId}`);\n        }\n      }\n    };\n\n    // Listen for our custom navigation events\n    document.addEventListener('builderPageNavigation', handleNavigationEvent);\n    document.addEventListener('pageNavigation', handleNavigationEvent);\n    window.addEventListener('builderPageNavigation', handleNavigationEvent);\n    window.addEventListener('pageNavigation', handleNavigationEvent);\n\n    return () => {\n      document.removeEventListener('builderPageNavigation', handleNavigationEvent);\n      document.removeEventListener('pageNavigation', handleNavigationEvent);\n      window.removeEventListener('builderPageNavigation', handleNavigationEvent);\n      window.removeEventListener('pageNavigation', handleNavigationEvent);\n    };\n  }, [builderPages, activeBuilderPageId]);\n\n  // Helper functions to get current page data\n  const getCurrentBuilderPage = (): BuilderPage => {\n    return builderPages.find(p => p.id === activeBuilderPageId) || builderPages[0];\n  };\n\n  //