able.value.trim() ? '#28a745' : '#6c757d',\r\n                color: 'white',\r\n                border: 'none',\r\n                borderRadius: '4px',\r\n                fontSize: '14px',\r\n                fontWeight: '600',\r\n                cursor: newVariable.name.trim() && newVariable.value.trim() ? 'pointer' : 'not-allowed'\r\n              }}\r\n            >\r\n              ✅ Create Variable\r\n            </button>\r\n            <button\r\n              onClick={() => {\r\n                setNewVariable({ name: '', type: 'string', value: '', description: '' });\r\n                setShowCreateForm(false);\r\n              }}\r\n              style={{\r\n                padding: '10px 20px',\r\n                backgroundColor: 'transparent',\r\n                color: '#6c757d',\r\n                border: '1px solid #dee2e6',\r\n                borderRadius: '4px',\r\n                fontSize: '14px',\r\n                cursor: 'pointer'\r\n              }}\r\n            >\r\n              Cancel\r\n            </button>\r\n          </div>\r\n        </div>\r\n      )}\r\n\r\n      {/* Variables List */}\r\n      {filteredVariables.length === 0 ? (\r\n        <div style={{\r\n          textAlign: 'center',\r\n          padding: '40px',\r\n          color: '#6c757d'\r\n        }}>\r\n          {searchTerm || filterType !== 'all' ? (\r\n            <>\r\n              <h3>No variables found</h3>\r\n              <p>Try adjusting your search or filter criteria</p>\r\n            </>\r\n          ) : (\r\n            <>\r\n              <h3>No variables available</h3>\r\n              <p>Create API connections or global variables to see them here</p>\r\n            </>\r\n          )}\r\n        </div>\r\n      ) : (\r\n        <div style={{\r\n          border: '1px solid #dee2e6',\r\n          borderRadius: '8px',\r\n          overflow: 'hidden'\r\n        }}>\r\n          {/* Table Header */}\r\n          <div style={{\r\n            display: 'grid',\r\