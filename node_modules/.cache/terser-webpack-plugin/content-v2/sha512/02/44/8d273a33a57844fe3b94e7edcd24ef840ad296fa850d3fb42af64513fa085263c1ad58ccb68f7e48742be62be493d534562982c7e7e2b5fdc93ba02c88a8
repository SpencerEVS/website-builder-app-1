      <select\r\n                                    value={activeConnectionData.trigger.condition.operator}\r\n                                    onChange={(e) => {\r\n                                        // @ts-ignore\r\n                                        const condition = activeConnectionData.trigger.condition || { variable: '', operator: '==', value: '' };\r\n                                        handleUpdateConnection(activeConnectionData.id, {\r\n                                            trigger: {\r\n                                                ...activeConnectionData.trigger,\r\n                                                // @ts-ignore\r\n                                                condition: { ...condition, operator: e.target.value }\r\n                                            }\r\n                                        });\r\n                                    }}\r\n                                    style={{\r\n                                        padding: '4px',\r\n                                        fontSize: '11px',\r\n                                        border: '1px solid #ced4da',\r\n                                        borderRadius: '3px'\r\n                                    }}\r\n                                >\r\n                                    <option value=\"==\">=</option>\r\n                                    <option value=\"!=\">≠</option>\r\n                                    <option value=\">\">&gt;</option>\r\n                                    <option value=\"<\">&lt;</option>\r\n                                    <option value=\">=\">&gt;=</option>\r\n                                    <option value=\"<=\">&lt;=</option>\r\n                                </select>\r\n                                <input\r\n                                    type=\"text\"\r\n                                    placeholder=\"Value\"\r\n                                    value={String(activeConne